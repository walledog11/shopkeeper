{
  "name": "shopkeeper-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "predev": "npm run db:generate -w packages/db && npm run build -w packages/db && npm run build -w packages/email && npm run build -w packages/agent",
    "dev": "npx turbo run dev",
    "build": "npx turbo run build",
    "clean": "node ./scripts/clean.mjs artifacts",
    "clean:deps": "node ./scripts/clean.mjs deps",
    "lint": "npm run lint:structure && npm run lint:repo && npx turbo run lint",
    "typecheck": "npx turbo run typecheck",
    "lint:structure": "node ./scripts/check-module-structure.mjs && node ./scripts/check-test-config-overlap.mjs",
    "lint:repo": "eslint e2e scripts playwright.config.ts playwright.browser.config.ts eslint.config.mjs --max-warnings 0",
    "db:push": "npx turbo run db:push",
    "db:generate": "npx turbo run db:generate",
    "db:migrate:deploy": "npx prisma migrate deploy --schema=packages/db/prisma/schema.prisma",
    "test": "npm run test:unit && npm run test:node && npm run test:integration",
    "verify:pr": "npm run lint:structure && npm run lint:repo && npx turbo run lint && npm run test:unit && npm run test:node && npm run test:integration && npm run test:e2e:smoke && npm run test:coverage && npm run build",
    "test:unit": "npx turbo run test:unit --env-mode=loose",
    "test:node": "node --test scripts/*.test.mjs",
    "test:services:up": "node ./scripts/test-services.mjs up",
    "test:services:down": "node ./scripts/test-services.mjs down",
    "test:services:status": "node ./scripts/test-services.mjs status",
    "test:integration": "node ./scripts/test-bootstrap.mjs && npx turbo run test:integration --env-mode=loose",
    "test:coverage": "node ./scripts/test-bootstrap.mjs && npm run test:coverage -w apps/dashboard && npm run test:coverage -w apps/gateway",
    "test:integration:local": "node ./scripts/test-integration-local.mjs",
    "test:e2e": "npm run test:e2e:smoke && npm run test:e2e:browser",
    "test:e2e:smoke": "E2E_AUTH_BYPASS=true node ./scripts/with-test-env.mjs npx playwright test --config=playwright.config.ts",
    "test:e2e:browser": "E2E_AUTH_BYPASS=false node ./scripts/with-test-env.mjs npx playwright test --config=playwright.browser.config.ts",
    "verify:production:env": "node ./scripts/check-production-env.mjs all",
    "verify:production": "node ./scripts/verify-production.mjs",
    "verify:production:alerts": "node ./scripts/verify-production-alerts.mjs"
  },
  "devDependencies": {
    "@clerk/testing": "^2.0.22",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@types/node": "^20",
    "dotenv": "^16.4.5",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "globals": "^16.4.0",
    "prisma": "6.19.3",
    "turbo": "^2.9.5",
    "typescript": "^5",
    "typescript-eslint": "^8.46.0"
  },
  "dependencies": {
    "@prisma/client": "6.19.3"
  },
  "packageManager": "npm@10.9.3",
  "overrides": {
    "prisma": "6.19.3",
    "@prisma/client": "6.19.3",
    "js-cookie": "^3.0.6"
  }
}
