{
  "name": "clerk-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "predev": "npm run db:generate -w packages/db && npm run build -w packages/db",
    "dev": "npx turbo run dev",
    "build": "npx turbo run build",
    "lint": "npm run lint:structure && npm run lint:repo && npx turbo run lint",
    "lint:structure": "node ./scripts/check-module-structure.mjs",
    "lint:repo": "eslint e2e scripts playwright.config.ts eslint.config.mjs",
    "db:push": "npx turbo run db:push",
    "db:generate": "npx turbo run db:generate",
    "db:migrate:deploy": "npx prisma migrate deploy --schema=packages/db/prisma/schema.prisma",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "npx turbo run test:unit --env-mode=loose",
    "test:services:up": "node ./scripts/test-services.mjs up",
    "test:services:down": "node ./scripts/test-services.mjs down",
    "test:services:status": "node ./scripts/test-services.mjs status",
    "test:integration": "node ./scripts/test-bootstrap.mjs && npx turbo run test:integration --env-mode=loose",
    "test:integration:local": "node ./scripts/test-integration-local.mjs",
    "test:e2e": "node ./scripts/test-bootstrap.mjs && node ./scripts/with-test-env.mjs npx playwright test",
    "verify:production:env": "node ./scripts/check-production-env.mjs all",
    "verify:production": "node ./scripts/verify-production.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@types/node": "^20",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "globals": "^16.4.0",
    "prisma": "6.19.2",
    "turbo": "^2.9.5",
    "typescript": "^5",
    "typescript-eslint": "^8.46.0"
  },
  "dependencies": {
    "@prisma/client": "6.19.2"
  },
  "packageManager": "npm@10.9.3",
  "overrides": {
    "prisma": "6.19.2",
    "@prisma/client": "6.19.2"
  }
}
