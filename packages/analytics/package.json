{
  "name": "@shopkeeper/analytics",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc -p tsconfig.json --noEmit --pretty false",
    "dev": "tsc --watch --preserveWatchOutput",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:coverage": "node ../../scripts/with-test-env.mjs vitest run --coverage --config vitest.config.ts",
    "lint": "cd ../.. && eslint packages/analytics/src packages/analytics/vitest.config.ts --max-warnings 0"
  },
  "dependencies": {
    "posthog-node": "^5.8.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.3",
    "typescript": "latest",
    "vitest": "^4.1.3"
  }
}
