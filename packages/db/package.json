{
  "name": "@shopkeeper/db",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./test-helpers": {
      "types": "./dist/test-helpers.d.ts",
      "default": "./dist/test-helpers.js"
    },
    "./customer-memory": {
      "types": "./dist/customer-memory.d.ts",
      "default": "./dist/customer-memory.js"
    }
  },
  "scripts": {
    "postinstall": "prisma generate --schema=prisma/schema.prisma && tsc",
    "build": "tsc",
    "dev": "npm run db:generate && tsc --watch --preserveWatchOutput",
    "lint": "cd ../.. && eslint packages/db/*.ts packages/db/scripts/*.ts --max-warnings 0",
    "db:generate": "prisma generate",
    "db:push": "prisma db push"
  },
  "devDependencies": {
    "typescript": "latest"
  },
  "dependencies": {
    "@neondatabase/serverless": "0.10.4",
    "@prisma/adapter-neon": "6.19.3",
    "@prisma/client": "6.19.3",
    "prisma": "6.19.3"
  }
}
