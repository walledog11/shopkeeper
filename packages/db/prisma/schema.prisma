// This is your Prisma schema file.
// It defines the universal data model for Shopkeeper.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// --- ENUMS ---
enum ChannelType {
  ig_dm
  email
  tiktok
  shopify
  sms
  sms_agent
  dashboard_agent
  imessage
}

enum EmailProvider {
  gmail
  postmark
}

enum ThreadStatus {
  open
  pending
  closed
}

enum SenderType {
  customer
  agent
  ai
  note
}

enum ThreadFilterStatus {
  genuine
  questionable
  filtered
}

enum ThreadFilterFeedback {
  none
  confirmed_genuine
  confirmed_spam
}

enum PlanExecutionStatus {
  pending
  claimed
  committed
  failed
  unknown
}

enum RefundSpendReservationStatus {
  reserved
  committed
  released
  unknown
}

enum OperatorEventStatus {
  pending
  claimed
  committed
  failed
  unknown
}

enum StripeWebhookEventStatus {
  pending
  processing
  completed
  failed
}

// --- MODELS ---

// One Organization = one Shopify business using the app.
// clerkOrgId maps to the organization ID from Clerk.com (e.g. org_xxxx).
model Organization {
  id                        String   @id @default(uuid()) @db.Uuid
  clerkOrgId                String   @unique @map("clerk_org_id")
  name                      String   @db.VarChar(255)
  settings                  Json?    @default("{}") @map("settings") @db.JsonB
  defaultEmailIntegrationId String?  @map("default_email_integration_id") @db.Uuid
  // Pending brand-voice update synthesized from operator edits, awaiting approval.
  // Shape: { brief, rationale, basedOnCount, createdAt }. Cleared on approve/dismiss.
  voiceProposal             Json?    @map("voice_proposal") @db.JsonB
  createdAt                 DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                 DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  stripeCustomerId          String?   @unique @map("stripe_customer_id") @db.VarChar(255)
  stripeSubscriptionId      String?   @unique @map("stripe_subscription_id") @db.VarChar(255)
  stripePriceId             String?   @map("stripe_price_id") @db.VarChar(255)
  stripeStatus              String?   @map("stripe_status") @db.VarChar(50)
  trialEndsAt               DateTime? @map("trial_ends_at") @db.Timestamptz
  stripeStateEventCreatedAt DateTime? @map("stripe_state_event_created_at") @db.Timestamptz
  stripeStateEventId        String?   @map("stripe_state_event_id") @db.VarChar(255)

  customers               Customer[]
  threads                 Thread[]
  integrations            Integration[]            @relation("OrganizationIntegrations")
  defaultEmailIntegration Integration?             @relation("DefaultEmailIntegration", fields: [defaultEmailIntegrationId], references: [id], onDelete: SetNull)
  members                 OrgMember[]
  operatorContexts        OperatorContext[]
  operatorEvents          OperatorEvent[]
  bindTokens              OrgMemberBindToken[]
  knowledgeBases          KnowledgeBase[]
  kbArticles              KbArticle[]
  kbCitations             KbCitation[]
  agentActions            AgentAction[]
  voiceEdits              VoiceEdit[]
  llmDailySpend           LlmDailySpend[]
  refundDailySpend        RefundDailySpend[]
  refundSpendReservations RefundSpendReservation[]
  shadowDecisions         AutonomyShadowDecision[]
  planExecutions          PlanExecution[]
  stripeWebhookEvents     StripeWebhookEvent[]
  messages                Message[]

  @@index([clerkOrgId])
  @@map("organizations")
}

// Durable processing record for Stripe webhooks. The signed event body is not
// retained; Stripe redelivers it when a failed/active claim returns a retryable
// response. Organization billing state and event completion commit together.
model StripeWebhookEvent {
  id              String                   @id @db.VarChar(255)
  type            String                   @map("event_type") @db.VarChar(255)
  stripeCreatedAt DateTime                 @map("stripe_created_at") @db.Timestamptz
  customerId      String?                  @map("customer_id") @db.VarChar(255)
  subscriptionId  String?                  @map("subscription_id") @db.VarChar(255)
  organizationId  String?                  @map("organization_id") @db.Uuid
  status          StripeWebhookEventStatus @default(pending)
  claimToken      String?                  @map("claim_token") @db.Uuid
  claimedAt       DateTime?                @map("claimed_at") @db.Timestamptz
  processedAt     DateTime?                @map("processed_at") @db.Timestamptz
  attempts        Int                      @default(0)
  lastError       String?                  @map("last_error") @db.Text
  createdAt       DateTime                 @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime                 @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([status, claimedAt])
  @@index([organizationId, stripeCreatedAt])
  @@index([customerId, stripeCreatedAt])
  @@map("stripe_webhook_events")
}

// Per-org daily LLM spend backstop. One row per (org, UTC day) holding the
// running total in integer nano-dollars. Dashboard and gateway both upsert
// here so the daily cap is enforced per-org across both apps.
model LlmDailySpend {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  day            String   @map("day") @db.VarChar(10)
  model          String   @map("model") @db.VarChar(64)
  spentNanoUsd   BigInt   @default(0) @map("spent_nano_usd")
  calls          Int      @default(0) @map("calls")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, day, model])
  @@map("llm_daily_spend")
}

// Per-org daily refund-cap backstop. One row per (org, UTC day) holding the
// running refund total in integer cents. Dashboard and gateway both upsert here
// so the daily refund cap is enforced per-org across both apps (the same reason
// llm_daily_spend lives in Postgres rather than per-instance Redis).
model RefundDailySpend {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  day            String   @map("day") @db.VarChar(10)
  spentCents     Int      @default(0) @map("spent_cents")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, day])
  @@map("refund_daily_spend")
}

// One durable budget claim per goodwill-spend tool intent. Reservations count
// against the daily cap before the provider call; committed rows move their
// verified amount into RefundDailySpend, released rows free the capacity, and
// unknown rows keep capacity reserved until reconciliation proves an outcome.
model RefundSpendReservation {
  id             String                       @id @default(uuid()) @db.Uuid
  organizationId String                       @map("organization_id") @db.Uuid
  day            String                       @db.VarChar(10)
  operationKey   String                       @map("operation_key") @db.VarChar(255)
  tool           String                       @db.VarChar(64)
  input          Json                         @db.JsonB
  reservedCents  Int                          @map("reserved_cents")
  committedCents Int?                         @map("committed_cents")
  status         RefundSpendReservationStatus @default(reserved)
  lastError      String?                      @map("last_error") @db.Text
  resolvedAt     DateTime?                    @map("resolved_at") @db.Timestamptz
  createdAt      DateTime                     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime                     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, day, operationKey])
  @@index([organizationId, day, status])
  @@index([status, updatedAt])
  @@map("refund_spend_reservations")
}

// Corpus for the brand-voice learning loop: each row is one case where the
// operator sent a customer reply that meaningfully diverged from the agent's
// drafted reply. A daily worker synthesizes these into a proposed brandVoice
// update (Organization.voiceProposal), then marks the consumed rows.
model VoiceEdit {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  threadId       String?   @map("thread_id") @db.Uuid
  aiDraft        String    @map("ai_draft") @db.Text
  finalText      String    @map("final_text") @db.Text
  tag            String?   @db.VarChar(255)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  consumedAt     DateTime? @map("consumed_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, consumedAt, createdAt])
  @@map("voice_edits")
}

// Stores a connected platform account for an organization.
// e.g. Instagram page, support email address, Shopify store.
model Integration {
  id                String         @id @default(uuid()) @db.Uuid
  organizationId    String         @map("organization_id") @db.Uuid
  platform          ChannelType
  emailProvider     EmailProvider? @map("email_provider")
  externalAccountId String         @map("external_account_id") @db.VarChar(255)
  fromEmail         String?        @map("from_email") @db.VarChar(255)
  accessToken       String?        @map("access_token") @db.Text
  refreshToken      String?        @map("refresh_token") @db.Text
  tokenExpiresAt    DateTime?      @map("token_expires_at") @db.Timestamptz
  metadata          Json?          @default("{}") @db.JsonB
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz

  organization            Organization   @relation("OrganizationIntegrations", fields: [organizationId], references: [id], onDelete: Cascade)
  defaultForOrganizations Organization[] @relation("DefaultEmailIntegration")
  replyThreads            Thread[]       @relation("ThreadReplyIntegration")
  messages                Message[]

  @@unique([organizationId, emailProvider])
  // Supporting identity for database-level tenant-consistency foreign keys.
  // The id remains the Prisma relation key; the compound index lets PostgreSQL
  // prove that a referenced integration belongs to the child row's tenant.
  @@unique([organizationId, id], map: "integrations_organization_id_id_key")
  // Non-email account uniqueness is enforced by the partial raw-SQL index
  // integrations_non_email_account_unique. Email rows are unique by provider
  // and may intentionally share the same external address.
  @@index([organizationId])
  @@map("integrations")
}

model Customer {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  name           String?   @db.VarChar(255)
  platformId     String    @map("platform_id") @db.VarChar(255)
  profilePicUrl  String?   @map("profile_pic_url") @db.Text
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  threads      Thread[]

  // platformId is unique per org, not globally — two orgs can share the same customer email
  @@unique([organizationId, platformId])
  @@unique([organizationId, id], map: "customers_organization_id_id_key")
  @@index([organizationId])
  @@index([deletedAt])
  @@map("customers")
}

model Thread {
  id                        String               @id @default(uuid()) @db.Uuid
  organizationId            String               @map("organization_id") @db.Uuid
  customerId                String               @map("customer_id") @db.Uuid
  channelType               ChannelType          @map("channel_type")
  status                    ThreadStatus         @default(open)
  createdAt                 DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                 DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  lastMessageAt             DateTime             @default(now()) @map("last_message_at") @db.Timestamptz
  lastMessageSenderType     SenderType?          @map("last_message_sender_type")
  aiSummary                 String?              @map("ai_summary")
  aiTitle                   String?              @map("ai_title")
  subject                   String?
  tag                       String?              @default("Support")
  shopifyCustomerId         String?              @map("shopify_customer_id") @db.VarChar(255)
  operatorKey               String?              @map("operator_key")
  externalSpaceId           String?              @map("external_space_id")
  cachedPlanMessageId       String?              @map("cached_plan_message_id") @db.Uuid
  cachedPlan                Json?                @map("cached_plan") @db.JsonB
  archivedAt                DateTime?            @map("archived_at") @db.Timestamptz
  deletedAt                 DateTime?            @map("deleted_at") @db.Timestamptz
  // Escalation is orthogonal to lifecycle status (P5-04): an escalated ticket
  // stays `open` so it remains in the inbox and inbound follow-ups correlate to
  // it. Set when the agent hands off to the merchant; null otherwise.
  escalatedAt               DateTime?            @map("escalated_at") @db.Timestamptz
  filterStatus              ThreadFilterStatus   @default(genuine) @map("filter_status")
  filterReason              String?              @map("filter_reason") @db.Text
  filterDecidedAt           DateTime?            @map("filter_decided_at") @db.Timestamptz
  filterFeedback            ThreadFilterFeedback @default(none) @map("filter_feedback")
  classifierSignals         Json?                @map("classifier_signals") @db.JsonB
  replyIntegrationId        String?              @map("reply_integration_id") @db.Uuid
  replyIntegrationUpdatedAt DateTime?            @map("reply_integration_updated_at") @db.Timestamptz

  organization     Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer         Customer                 @relation(fields: [customerId], references: [id], onDelete: Cascade)
  replyIntegration Integration?             @relation("ThreadReplyIntegration", fields: [replyIntegrationId], references: [id], onDelete: SetNull)
  messages         Message[]
  kbCitations      KbCitation[]
  agentActions     AgentAction[]
  shadowDecisions  AutonomyShadowDecision[]
  planExecutions   PlanExecution[]

  @@unique([organizationId, operatorKey])
  @@unique([organizationId, id], map: "threads_organization_id_id_key")
  @@index([organizationId, status])
  @@index([organizationId, updatedAt])
  @@index([organizationId, status, lastMessageAt(sort: Desc)])
  @@index([organizationId, status, lastMessageSenderType])
  @@index([customerId])
  @@index([organizationId, archivedAt, status])
  @@index([deletedAt])
  @@index([organizationId, filterStatus, filterDecidedAt(sort: Desc)])
  @@map("threads")
}

model Message {
  id                String     @id @default(uuid()) @db.Uuid
  threadId          String     @map("thread_id") @db.Uuid
  organizationId    String     @map("organization_id") @db.Uuid
  integrationId     String?    @map("integration_id") @db.Uuid
  senderType        SenderType @map("sender_type")
  contentText       String?    @map("content_text") @db.Text
  mediaUrl          String?    @map("media_url") @db.Text
  attachments       String[]   @default([])
  // Org-scoped idempotency for non-null provider message ids is enforced by
  // raw SQL migration 20260607000000_scope_message_idempotency_by_org.
  // Prisma cannot express the partial unique index:
  // messages_org_external_id_unique on (organization_id, external_message_id)
  // where external_message_id is not null.
  externalMessageId String?    @map("external_message_id") @db.Text
  sendStatus        String?    @map("send_status") @db.Text
  sendClaimToken    String?    @map("send_claim_token") @db.Uuid
  sendClaimedAt     DateTime?  @map("send_claimed_at") @db.Timestamptz
  sendAttemptedAt   DateTime?  @map("send_attempted_at") @db.Timestamptz
  providerMessageId String?    @map("provider_message_id") @db.Text
  sendError         String?    @map("send_error") @db.Text
  sentAt            DateTime   @default(now()) @map("sent_at") @db.Timestamptz
  deletedAt         DateTime?  @map("deleted_at") @db.Timestamptz

  thread               Thread          @relation(fields: [threadId], references: [id], onDelete: Cascade)
  organization         Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  integration          Integration?    @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  sourcePlanExecutions PlanExecution[] @relation("PlanExecutionSourceMessage")

  @@unique([organizationId, id], map: "messages_organization_id_id_key")
  @@unique([organizationId, id, threadId], map: "messages_organization_id_id_thread_id_key")
  @@index([threadId])
  @@index([organizationId])
  @@index([integrationId])
  @@index([sendStatus, sendClaimedAt])
  @@index([sentAt])
  @@index([deletedAt])
  @@map("messages")
}

// Per-organization/device operator-channel state. `chatId` is the channel
// context key: a Telegram chat id or an iMessage sender id.
model OperatorContext {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  chatId          String   @map("chat_id") @db.VarChar(64)
  pendingPlan     Json?    @map("pending_plan") @db.JsonB
  pendingDigest   Json?    @map("pending_digest") @db.JsonB
  pendingQuestion Json?    @map("pending_question") @db.JsonB
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, chatId])
  @@index([organizationId])
  @@map("operator_contexts")
}

// Durable ingestion record for one inbound operator-channel message (P4-03). The
// webhook persists this row and enqueues before acknowledging, so an acknowledged
// merchant instruction survives a crash and is recoverable. The unique
// (channel, providerMessageId) absorbs provider redeliveries; the claim
// (pending -> claimed) makes each message drive at most one control action — the
// only single-use guard for free-form operator turns, which carry no plan claim.
// Turn commit (status/processedAt) is tracked separately from reply delivery
// (replyText/replyDeliveredAt) so a stuck confirmation can be re-sent without
// re-running the side-effectful turn.
model OperatorEvent {
  id                String              @id @default(uuid()) @db.Uuid
  organizationId    String              @map("organization_id") @db.Uuid
  channel           String              @db.VarChar(16)
  providerMessageId String              @map("provider_message_id") @db.VarChar(255)
  chatId            String              @map("chat_id") @db.VarChar(255)
  spaceId           String?             @map("space_id") @db.VarChar(255)
  clerkUserId       String              @map("clerk_user_id") @db.VarChar(255)
  operatorKey       String              @map("operator_key") @db.VarChar(255)
  body              String              @db.Text
  metadata          Json?               @db.JsonB
  status            OperatorEventStatus @default(pending)
  claimToken        String?             @map("claim_token") @db.Uuid
  claimedAt         DateTime?           @map("claimed_at") @db.Timestamptz
  processedAt       DateTime?           @map("processed_at") @db.Timestamptz
  replyText         String?             @map("reply_text") @db.Text
  replyDeliveredAt  DateTime?           @map("reply_delivered_at") @db.Timestamptz
  attempts          Int                 @default(0)
  lastError         String?             @map("last_error") @db.Text
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([channel, providerMessageId])
  @@index([organizationId, status, createdAt])
  @@index([status, updatedAt])
  @@map("operator_events")
}

// Extends Clerk.com org membership with operator-channel bindings so team
// members can interact with the AI agent over Telegram and iMessage.
model OrgMember {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  clerkUserId    String   @map("clerk_user_id") @db.VarChar(255)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization     Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  telegramChats    OrgMemberTelegramChat[]
  imessageBindings OrgMemberImessageBinding[]

  @@unique([organizationId, clerkUserId])
  @@index([organizationId])
  @@map("org_members")
}

// One row per Telegram chat bound to an org member. A single member can have
// up to MAX_TELEGRAM_DEVICES (3) rows; a given chatId can only be bound to one
// member at a time (enforced by the unique constraint on chat_id).
model OrgMemberTelegramChat {
  id             String   @id @default(uuid()) @db.Uuid
  orgMemberId    String   @map("org_member_id") @db.Uuid
  chatId         String   @map("chat_id") @db.VarChar(64)
  telegramUserId String?  @map("telegram_user_id") @db.VarChar(64)
  displayName    String?  @map("display_name") @db.VarChar(255)
  username       String?  @db.VarChar(255)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  orgMember OrgMember @relation(fields: [orgMemberId], references: [id], onDelete: Cascade)

  @@unique([chatId])
  @@index([orgMemberId])
  @@map("org_member_telegram_chats")
}

// One row per iMessage sender handle bound to an org member. iMessage is an
// operator channel (mirrors Telegram): the merchant texts Shopkeeper's single
// platform Spectrum line and the agent replies. The binding resolves which org
// an inbound sender belongs to. senderId (the merchant's handle) is globally
// unique — one handle binds to one member at a time, matching
// OrgMemberTelegramChat.chatId. spaceId is the Spectrum space used to reply.
model OrgMemberImessageBinding {
  id          String   @id @default(uuid()) @db.Uuid
  orgMemberId String   @map("org_member_id") @db.Uuid
  senderId    String   @unique @map("sender_id") @db.VarChar(255)
  spaceId     String   @map("space_id") @db.VarChar(255)
  displayName String?  @map("display_name") @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  orgMember OrgMember @relation(fields: [orgMemberId], references: [id], onDelete: Cascade)

  @@index([orgMemberId])
  @@map("org_member_imessage_bindings")
}

// Single-use deep-link tokens for binding operator channels (Telegram, iMessage).
// Stored in Postgres so dashboard (Upstash REST) and gateway (dedicated REDIS_URL)
// can both mint and consume tokens without sharing a Redis instance.
model OrgMemberBindToken {
  token          String   @id @db.VarChar(64)
  organizationId String   @map("organization_id") @db.Uuid
  clerkUserId    String   @map("clerk_user_id") @db.VarChar(255)
  expiresAt      DateTime @map("expires_at") @db.Timestamptz
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@map("org_member_bind_tokens")
}

model KnowledgeBase {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String   @db.VarChar(255)
  source         String   @default("user") @db.VarChar(50)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  articles     KbArticle[]

  @@unique([organizationId, id], map: "knowledge_bases_organization_id_id_key")
  @@index([organizationId])
  @@map("knowledge_bases")
}

model KbArticle {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  knowledgeBaseId String   @map("knowledge_base_id") @db.Uuid
  title           String   @db.VarChar(255)
  body            String   @db.Text
  tags            String[] @default([])
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  knowledgeBase KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  citations     KbCitation[]

  @@unique([organizationId, id], map: "kb_articles_organization_id_id_key")
  @@index([organizationId])
  @@index([knowledgeBaseId])
  @@map("kb_articles")
}

model KbCitation {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  kbArticleId    String   @map("kb_article_id") @db.Uuid
  threadId       String?  @map("thread_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  article      KbArticle    @relation(fields: [kbArticleId], references: [id], onDelete: Cascade)
  thread       Thread?      @relation(fields: [threadId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([kbArticleId, createdAt])
  @@map("kb_citations")
}

// First-class audit record for every agent tool call. Replaces the
// __clerk_agent__ note-row parsing in lib/agent/api/action-log.ts.
//   status:   success | error | policy_block | escalated | unknown
//   mode:     human_approved | auto_executed | read_only
//   category: mirrors TOOL_CATEGORIES from lib/agent/tools/registry.ts
model AgentAction {
  id               String    @id @default(uuid()) @db.Uuid
  turnId           String    @map("turn_id") @db.Uuid
  organizationId   String    @map("organization_id") @db.Uuid
  threadId         String?   @map("thread_id") @db.Uuid
  customerId       String?   @map("customer_id") @db.Uuid
  executionId      String?   @map("execution_id") @db.Uuid
  tool             String    @db.VarChar(64)
  category         String    @db.VarChar(32)
  input            Json      @db.JsonB
  output           String?   @db.Text
  status           String    @db.VarChar(32)
  errorDetail      String?   @map("error_detail") @db.Text
  mode             String    @db.VarChar(32)
  instruction      String?   @db.Text
  summary          String?   @db.Text
  approverId       String?   @map("approver_id") @db.VarChar(255)
  approvedAt       DateTime? @map("approved_at") @db.Timestamptz
  approvedPlanHash String?   @map("approved_plan_hash") @db.VarChar(64)
  instructionHash  String?   @map("instruction_hash") @db.VarChar(64)
  feedback         String?   @db.VarChar(16)
  executedAt       DateTime  @default(now()) @map("executed_at") @db.Timestamptz
  durationMs       Int       @map("duration_ms")

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  thread       Thread?        @relation(fields: [threadId], references: [id], onDelete: SetNull)
  execution    PlanExecution? @relation(fields: [executionId], references: [id], onDelete: SetNull)

  @@index([organizationId, executedAt(sort: Desc)])
  @@index([organizationId, threadId])
  @@index([organizationId, tool, executedAt])
  @@index([organizationId, status])
  @@index([turnId])
  @@index([executionId])
  @@map("agent_actions")
}

// Durable, cross-runtime identity and claim state for one reviewed agent plan.
// P1-01 adds this ledger additively; P1-02 makes every reviewed-plan entry point
// claim it before side effects. `observationCount` supports shadow rollout
// without treating timing locks as the correctness boundary.
model PlanExecution {
  id               String              @id @default(uuid()) @db.Uuid
  planId           String              @map("plan_id") @db.Uuid
  organizationId   String              @map("organization_id") @db.Uuid
  threadId         String?             @map("thread_id") @db.Uuid
  sourceMessageId  String?             @map("source_message_id") @db.Uuid
  planHash         String              @map("plan_hash") @db.VarChar(64)
  instructionHash  String              @map("instruction_hash") @db.VarChar(64)
  status           PlanExecutionStatus @default(pending)
  claimToken       String?             @map("claim_token") @db.Uuid
  claimedAt        DateTime?           @map("claimed_at") @db.Timestamptz
  completedAt      DateTime?           @map("completed_at") @db.Timestamptz
  approverId       String?             @map("approver_id") @db.VarChar(255)
  approvedAt       DateTime?           @map("approved_at") @db.Timestamptz
  mode             String?             @db.VarChar(32)
  lastError        String?             @map("last_error") @db.Text
  observationCount Int                 @default(0) @map("observation_count")
  lastObservedAt   DateTime?           @map("last_observed_at") @db.Timestamptz
  createdAt        DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  thread        Thread?       @relation(fields: [threadId], references: [id], onDelete: SetNull)
  sourceMessage Message?      @relation("PlanExecutionSourceMessage", fields: [sourceMessageId], references: [id], onDelete: SetNull)
  actions       AgentAction[]

  @@unique([organizationId, planId])
  @@unique([organizationId, id], map: "plan_executions_organization_id_id_key")
  @@index([organizationId, status, createdAt])
  @@index([organizationId, threadId, createdAt])
  @@index([sourceMessageId])
  @@map("plan_executions")
}

// Shadow/canary record for the autonomy raise. One row per plan ("turn") that
// the classifier would have auto-executed at the org's tier while autoExecuteMode
// is "shadow": the action still routes to human approval, and we record what the
// agent *would* have auto-done so it can be compared against what the human did.
// The shadow unit is per-plan (turnId), unlike per-tool-call AgentAction.
model AutonomyShadowDecision {
  id                    String    @id @default(uuid()) @db.Uuid
  turnId                String    @unique @map("turn_id") @db.Uuid
  organizationId        String    @map("organization_id") @db.Uuid
  threadId              String?   @map("thread_id") @db.Uuid
  tier                  String    @db.VarChar(16)
  proposedMutationsHash String    @map("proposed_mutations_hash") @db.VarChar(64)
  proposedTools         String[]  @map("proposed_tools")
  wouldAutoExecute      Boolean   @map("would_auto_execute")
  // pending | approved_unchanged | edited | rejected | escalated
  humanDecision         String    @default("pending") @map("human_decision") @db.VarChar(32)
  agreement             Boolean?  @map("agreement")
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz
  resolvedAt            DateTime? @map("resolved_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  thread       Thread?      @relation(fields: [threadId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([organizationId, humanDecision])
  @@index([organizationId, threadId, humanDecision])
  @@map("autonomy_shadow_decisions")
}
