// This is your Prisma schema file.
// It defines the universal data model for Clerk.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---
enum ChannelType {
  ig_dm
  email
  tiktok
  shopify
  sms
  sms_agent
}

enum ThreadStatus {
  open
  pending
  closed
}

enum SenderType {
  customer
  agent
  ai
  note
}

// --- MODELS ---

// One Organization = one Shopify business using the app.
// clerkOrgId maps to the organization ID from Clerk.com (e.g. org_xxxx).
model Organization {
  id          String   @id @default(uuid()) @db.Uuid
  clerkOrgId  String   @unique @map("clerk_org_id")
  name        String   @db.VarChar(255)
  settings    Json?    @default("{}") @map("settings") @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  stripeCustomerId     String?  @unique @map("stripe_customer_id") @db.VarChar(255)
  stripeSubscriptionId String?  @unique @map("stripe_subscription_id") @db.VarChar(255)
  stripePriceId        String?  @map("stripe_price_id") @db.VarChar(255)
  stripeStatus         String?  @map("stripe_status") @db.VarChar(50)
  trialEndsAt          DateTime? @map("trial_ends_at") @db.Timestamptz

  customers    Customer[]
  threads      Thread[]
  integrations Integration[]
  members      OrgMember[]

  @@index([clerkOrgId])
  @@map("organizations")
}

// Stores a connected platform account for an organization.
// e.g. Instagram page, support email address, Shopify store.
model Integration {
  id                String      @id @default(uuid()) @db.Uuid
  organizationId    String      @map("organization_id") @db.Uuid
  platform          ChannelType
  externalAccountId String      @map("external_account_id") @db.VarChar(255)
  fromEmail         String?     @map("from_email") @db.VarChar(255)
  accessToken       String?     @map("access_token") @db.Text
  tokenExpiresAt    DateTime?   @map("token_expires_at") @db.Timestamptz
  metadata          Json?       @default("{}") @db.JsonB
  createdAt         DateTime    @default(now()) @map("created_at") @db.Timestamptz

  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, platform, externalAccountId])
  @@index([organizationId])
  @@map("integrations")
}

model Customer {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  name           String?      @db.VarChar(255)
  platformId     String       @map("platform_id") @db.VarChar(255)
  profilePicUrl  String?      @map("profile_pic_url") @db.Text
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  threads        Thread[]

  // platformId is unique per org, not globally — two orgs can share the same customer email
  @@unique([organizationId, platformId])
  @@index([organizationId])
  @@map("customers")
}

model Thread {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  customerId     String       @map("customer_id") @db.Uuid
  channelType    ChannelType  @map("channel_type")
  status         ThreadStatus @default(open)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  aiSummary         String?  @map("ai_summary")
  tag               String?  @default("Support")
  shopifyCustomerId String?  @map("shopify_customer_id") @db.VarChar(255)

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  messages       Message[]

  @@index([organizationId, status])
  @@index([organizationId, updatedAt])
  @@index([customerId])
  @@map("threads")
}

model Message {
  id          String     @id @default(uuid()) @db.Uuid
  threadId    String     @map("thread_id") @db.Uuid
  senderType  SenderType @map("sender_type")
  contentText String?    @map("content_text") @db.Text
  mediaUrl    String?    @map("media_url") @db.Text
  sentAt      DateTime   @default(now()) @map("sent_at") @db.Timestamptz

  thread      Thread     @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([sentAt])
  @@map("messages")
}

// Extends Clerk.com org membership with a verified phone number so
// team members can interact with the AI agent via SMS / WhatsApp.
model OrgMember {
  id             String      @id @default(uuid()) @db.Uuid
  organizationId String      @map("organization_id") @db.Uuid
  clerkUserId    String      @map("clerk_user_id") @db.VarChar(255)
  phoneNumber    String?     @map("phone_number") @db.VarChar(20)
  phoneVerified  Boolean     @default(false) @map("phone_verified")
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, clerkUserId])
  @@unique([organizationId, phoneNumber])
  @@index([organizationId])
  @@index([phoneNumber])
  @@map("org_members")
}
