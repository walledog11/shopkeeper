{
  "name": "clerk-dashboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:e2e": "NEXT_DIST_DIR=.next-e2e next dev -p 3100",
    "build:e2e": "node ../../scripts/dashboard-e2e-build.mjs",
    "start:e2e": "NEXT_DIST_DIR=.next-e2e next start -p 3100",
    "serve:e2e": "node ../../scripts/test-bootstrap.mjs && npm run build:e2e && npm run start:e2e",
    "build": "next build",
    "lint": "cd ../.. && eslint apps/dashboard/src apps/dashboard/next.config.js apps/dashboard/postcss.config.mjs apps/dashboard/vitest.config.ts apps/dashboard/vitest.integration.config.ts apps/dashboard/vitest.unit.config.ts",
    "start": "next start",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "node ../../scripts/with-test-env.mjs vitest run --config vitest.unit.config.ts",
    "test:integration": "node ../../scripts/with-test-env.mjs vitest run --config vitest.integration.config.ts",
    "test:watch": "node ../../scripts/with-test-env.mjs vitest --config vitest.integration.config.ts",
    "test:coverage": "node ../../scripts/with-test-env.mjs vitest run --coverage --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.80.0",
    "@clerk/db": "*",
    "@clerk/nextjs": "7.3.3",
    "@clerk/shared": "4.10.2",
    "@sentry/nextjs": "10.47.0",
    "@upstash/redis": "^1.37.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "ioredis": "5.10.0",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "next": "16.2.6",
    "openai": "6.33.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postmark": "4.0.7",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "stripe": "^21.0.1",
    "swr": "2.4.1",
    "tailwind-merge": "^3.5.0",
    "twilio": "^5.13.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.3",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "vitest": "^4.1.3"
  }
}
