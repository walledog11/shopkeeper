{
  "id": "tier-full-refund-in-policy-auto",
  "description": "Full-tier org (default $1000 cap): refund request within policy and under the tier cap. The agent should issue the refund and reply without escalating, and the dashboard classifier marks the plan auto_execute.",
  "setup": {
    "channelType": "email",
    "tag": "Support",
    "customerName": "Noa Bennett",
    "customerPlatformId": "noa@example.com",
    "shopifyCustomerId": "10000004301",
    "shopify": { "shop": "test-store.myshopify.com", "accessToken": "shpat_test_fixture" },
    "orgSettings": { "autonomyTier": "full" },
    "messages": [
      { "senderType": "customer", "contentText": "Order #4301 - the sofa arrived with a torn cushion and I don't want a replacement. Please refund me the $600." }
    ],
    "simulateToolResults": [
      { "tool": "create_refund", "result": "Refund of $600.00 USD issued for order #4301." },
      { "tool": "send_reply", "result": "Reply sent to customer via email." }
    ],
    "recentOrders": [
      {
        "id": "9000004301",
        "name": "#4301",
        "created_at": "2026-05-14T11:00:00-07:00",
        "financial_status": "paid",
        "fulfillment_status": "fulfilled",
        "total_price": "600.00",
        "currency": "USD",
        "items": [
          {
            "line_item_id": "lineitem_4301",
            "title": "Linen Sofa",
            "quantity": 1,
            "variant_id": "variant_4301",
            "fulfillable_quantity": 0,
            "current_quantity": 1,
            "fulfillment_status": "fulfilled"
          }
        ]
      }
    ]
  },
  "instruction": "Reply to the customer and process their refund request.",
  "expectedPlan": {
    "mustCallTools": ["create_refund", "send_reply"],
    "mustNotCallTools": ["escalate_to_human", "cancel_order"],
    "mustCallToolsWithInput": [
      { "tool": "create_refund", "inputIncludes": { "order_id": "9000004301" } }
    ],
    "mustClassifyAs": "auto_execute",
    "expectedAgentActions": [
      { "tool": "create_refund", "status": "success", "mode": "auto_executed" },
      { "tool": "send_reply", "status": "success", "mode": "auto_executed" }
    ]
  }
}
