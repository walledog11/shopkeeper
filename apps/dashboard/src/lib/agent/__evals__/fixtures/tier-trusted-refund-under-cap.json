{
  "id": "tier-trusted-refund-under-cap",
  "description": "Trusted-tier org: refund request well under the $100 tier cap. The agent should issue the refund and reply without escalating, and the dashboard classifier marks the plan auto_execute.",
  "setup": {
    "channelType": "email",
    "tag": "Support",
    "customerName": "Morgan Lee",
    "customerPlatformId": "morgan@example.com",
    "shopifyCustomerId": "10000004003",
    "shopify": { "shop": "test-store.myshopify.com", "accessToken": "shpat_test_fixture" },
    "orgSettings": { "autonomyTier": "trusted" },
    "messages": [
      { "senderType": "customer", "contentText": "Hi, the tee I got was the wrong size and I don't want a replacement. Please refund me for order #4003." }
    ],
    "simulateToolResults": [
      { "tool": "create_refund", "result": "Refund of $42.00 USD issued for order #4003." },
      { "tool": "send_reply", "result": "Reply sent to customer via email." }
    ],
    "recentOrders": [
      {
        "id": "9000004003",
        "name": "#4003",
        "created_at": "2026-05-15T10:00:00-07:00",
        "financial_status": "paid",
        "fulfillment_status": "fulfilled",
        "total_price": "42.00",
        "currency": "USD",
        "items": [
          {
            "line_item_id": "lineitem_4003",
            "title": "Cotton Tee",
            "quantity": 1,
            "variant_id": "variant_4003",
            "fulfillable_quantity": 0,
            "current_quantity": 1,
            "fulfillment_status": "fulfilled"
          }
        ]
      }
    ]
  },
  "instruction": "Reply to the customer and process their refund request.",
  "expectedPlan": {
    "mustCallTools": ["create_refund", "send_reply"],
    "mustNotCallTools": ["escalate_to_human", "cancel_order"],
    "mustCallToolsWithInput": [
      { "tool": "create_refund", "inputIncludes": { "order_id": "9000004003" } }
    ],
    "mustClassifyAs": "auto_execute",
    "expectedAgentActions": [
      { "tool": "create_refund", "status": "success", "mode": "auto_executed" },
      { "tool": "send_reply", "status": "success", "mode": "auto_executed" }
    ]
  }
}
