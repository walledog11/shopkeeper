{
  "name": "shopkeeper-gateway",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "tunnel": "node ../../scripts/start-ngrok.mjs",
    "dev": "concurrently --kill-others-on-fail --names \"server,worker\" --prefix-colors \"bgBlue.bold,bgMagenta.bold\" \"tsx watch src/index.ts\" \"tsx watch src/worker.ts\"",
    "dev:tunnel": "concurrently --kill-others-on-fail --names \"server,worker,tunnel\" --prefix-colors \"bgBlue.bold,bgMagenta.bold,bgGreen.bold\" \"tsx watch src/index.ts\" \"tsx watch src/worker.ts\" \"npm run tunnel\"",
    "dev:e2e": "concurrently --kill-others-on-fail --names \"server,worker\" --prefix-colors \"bgBlue.bold,bgMagenta.bold\" \"tsx src/index.ts\" \"tsx src/worker.ts\"",
    "build": "tsc",
    "typecheck": "tsc -p tsconfig.json --noEmit --pretty false",
    "lint": "cd ../.. && eslint apps/gateway/src apps/gateway/vitest.config.ts apps/gateway/vitest.integration.config.ts apps/gateway/vitest.unit.config.ts --max-warnings 0",
    "start": "node dist/start.js",
    "start:server": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "node ../../scripts/with-test-env.mjs vitest run --config vitest.unit.config.ts",
    "test:integration": "node ../../scripts/with-test-env.mjs vitest run --config vitest.integration.config.ts",
    "test:watch": "node ../../scripts/with-test-env.mjs vitest --config vitest.integration.config.ts",
    "test:coverage": "node ../../scripts/with-test-env.mjs vitest run --coverage --config vitest.config.ts",
    "rebuild-summaries": "tsx src/scripts/rebuild-bad-summaries.ts",
    "backfill-titles": "tsx src/scripts/backfill-thread-titles.ts",
    "realtime:smoke": "tsx src/scripts/realtime-smoke.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.104.1",
    "@shopkeeper/agent": "*",
    "@shopkeeper/analytics": "*",
    "@shopkeeper/db": "*",
    "@shopkeeper/email": "*",
    "@vercel/blob": "2.3.3",
    "bullmq": "5.76.6",
    "dotenv": "^16.4.5",
    "express": "5.2.1",
    "google-auth-library": "^10.4.0",
    "ioredis": "5.10.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "spectrum-ts": "^4.2.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.19.17",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.3",
    "concurrently": "^10.0.3",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.3"
  }
}
