{
  "name": "clerk-gateway",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "tunnel": "ngrok http 8080 --url=darren-unalloyed-reina.ngrok-free.dev",
    "dev": "concurrently --kill-others-on-fail --names \"server,worker,tunnel\" --prefix-colors \"bgBlue.bold,bgMagenta.bold,bgGreen.bold\" \"tsx watch src/index.ts\" \"tsx watch src/worker.ts\" \"killall ngrok 2>/dev/null; sleep 1; ngrok http 8080 --url=darren-unalloyed-reina.ngrok-free.dev\"",
    "build": "tsc",
    "start": "node dist/start.js",
    "start:server": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "latest",
    "@clerk/db": "*",
    "@sentry/node": "latest",
    "bullmq": "latest",
    "dotenv": "^16.4.5",
    "express": "latest",
    "ioredis": "latest",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "twilio": "^5.13.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.19.17",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.3",
    "concurrently": "^9.2.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.3"
  }
}
