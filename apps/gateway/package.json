{
  "name": "shopkeeper-gateway",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "tunnel": "ngrok http 8080 --url=darren-unalloyed-reina.ngrok-free.dev",
    "dev": "concurrently --kill-others-on-fail --names \"server,worker,tunnel\" --prefix-colors \"bgBlue.bold,bgMagenta.bold,bgGreen.bold\" \"tsx watch src/index.ts\" \"tsx watch src/worker.ts\" \"killall ngrok 2>/dev/null; sleep 1; ngrok http 8080 --url=darren-unalloyed-reina.ngrok-free.dev\"",
    "dev:e2e": "concurrently --kill-others-on-fail --names \"server,worker\" --prefix-colors \"bgBlue.bold,bgMagenta.bold\" \"tsx src/index.ts\" \"tsx src/worker.ts\"",
    "build": "tsc",
    "lint": "cd ../.. && eslint apps/gateway/src apps/gateway/vitest.config.ts --max-warnings 0",
    "start": "node dist/start.js",
    "start:server": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "test": "npm run test:integration",
    "test:integration": "node ../../scripts/with-test-env.mjs vitest run --config vitest.config.ts",
    "test:watch": "node ../../scripts/with-test-env.mjs vitest --config vitest.config.ts",
    "test:coverage": "node ../../scripts/with-test-env.mjs vitest run --coverage --config vitest.config.ts",
    "rebuild-summaries": "tsx src/scripts/rebuild-bad-summaries.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.80.0",
    "@shopkeeper/agent": "*",
    "@shopkeeper/db": "*",
    "@sentry/node": "10.47.0",
    "@vercel/blob": "2.3.3",
    "bullmq": "5.76.6",
    "dotenv": "^16.4.5",
    "express": "5.2.1",
    "ioredis": "5.10.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.19.17",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.3",
    "concurrently": "^9.2.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.3"
  }
}
